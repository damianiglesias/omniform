{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omniform",
  "version": "0.2.0",
  "identifier": "com.damianiglesias.omniform",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Omniform",
        "width": 880,
        "height": 760,
        "minWidth": 640,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
  "icons/32x32.png",
  "icons/128x128.png",
  "icons/128x128@2x.png",
  "icons/icon.ico",
  "icons/icon.icns"
]
  }
}
