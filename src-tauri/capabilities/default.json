{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos por defecto para la ventana principal",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:scope-download-recursive",
    "fs:scope-home-recursive",
    "shell:allow-open",
    "clipboard-manager:allow-read-text"
  ]
}
